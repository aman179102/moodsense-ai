# Application Settings
APP_NAME=MoodSense AI v2
APP_VERSION=2.0.0
DEBUG=false
ENVIRONMENT=development

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Model Settings
MODEL_PATH=./models
DEFAULT_MODEL=mood_classifier_v2.pkl
EMBEDDING_MODEL=all-MiniLM-L6-v2

# NLP Settings
SPACY_MODEL=en_core_web_sm
USE_GPU=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# MLflow Settings
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=moodsense_experiments

# Hugging Face
HF_TOKEN=
HF_SPACE_NAME=

# Recommendation Settings
MAX_RECOMMENDATIONS=5
SIMILARITY_THRESHOLD=0.7
